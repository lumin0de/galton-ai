# ── Supabase ──────────────────────────────────────────────────────────────────
# Projeto: https://supabase.com/dashboard/project/<SEU_PROJECT_ID>
# Settings → API → Project URL
SUPABASE_URL=https://<PROJECT_ID>.supabase.co

# Settings → API → Project API keys → anon/public
SUPABASE_ANON_KEY=

# Settings → API → Project API keys → service_role  (⚠ manter em segredo)
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── API / Web ─────────────────────────────────────────────────────────────────
PORT=3001
# URL que o browser usa para chamar a API (dev local: http://localhost:3001)
VITE_API_URL=http://localhost:3001
