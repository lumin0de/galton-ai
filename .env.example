# ── Supabase ──────────────────────────────────────────────────────────────────
# Projeto: https://supabase.com/dashboard/project/<SEU_PROJECT_ID>
# Settings → API → Project URL
# Ex.: https://pzwefecmqkktcybeuohm.supabase.co
SUPABASE_URL=https://<PROJECT_ID>.supabase.co

# Settings → API → Project API keys → anon/public
SUPABASE_ANON_KEY=

# Settings → API → Project API keys → service_role  (⚠ manter em segredo)
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── API / Web ─────────────────────────────────────────────────────────────────
PORT=3001
# A URL da API no browser está fixa em web/src/lib/apiBaseUrl.ts (Edge galton-api).

# ── Edge Function galton-api (Supabase) ────────────────────────────────────────
# Deploy: npm run deploy:edge   (requer: npx supabase login && npx supabase link)
# Local:   npm run serve:edge   (requer Docker + secrets no .env)
# Secrets no Dashboard → Edge Functions → Secrets (ou: npx supabase secrets set KEY=value):
#   ANTHROPIC_API_KEY  (obrigatório para chat e dashboard-summary)
#   FRONTEND_ORIGIN    (opcional; CORS; padrão *)
# SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY são injetados automaticamente na Edge.
